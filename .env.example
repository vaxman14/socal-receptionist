# ----------------------------------------------------------------------------
# SoCal Receptionist — environment configuration
# Copy this file to ".env" for local development. In production, set these as
# environment variables in the DigitalOcean App Platform dashboard.
# Onboarding a new client = a new set of these values. No code changes needed.
# ----------------------------------------------------------------------------

# Server port (DigitalOcean App Platform injects this automatically)
PORT=8080

# --- Twilio (SMS: inbound + outbound) --------------------------------------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15555555555
# Set to false ONLY for local testing without a public Twilio webhook URL.
TWILIO_VALIDATE_SIGNATURE=true

# --- OpenAI (AI responses) --------------------------------------------------
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o

# --- Business profile (per-client configuration) ----------------------------
BUSINESS_NAME=Bright Smile Dental
BUSINESS_HOURS=Mon-Fri 8am-5pm, Sat 9am-1pm, closed Sunday
BUSINESS_SERVICES=Cleanings, exams, fillings, crowns, teeth whitening, emergency dental care
CALENDLY_LINK=https://calendly.com/bright-smile-dental/appointment
OWNER_EMAIL=owner@brightsmiledental.com

# --- Email notifications (Nodemailer SMTP) ----------------------------------
# Any SMTP provider works (e.g. SendGrid, Mailgun, Gmail app password, AWS SES).
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_smtp_password_or_api_key
# Optional. Defaults to: "<BUSINESS_NAME> Receptionist <SMTP_USER>"
SMTP_FROM=
