# SoCal Receptionist V2 — web app environment.
# Copy to .env.local for local dev; set as real env vars in Netlify.
# All VITE_ vars are bundled into the browser build — keep them browser-safe.

# Base URL of the V2 backend API. No trailing slash.
VITE_API_BASE=https://api.socalreceptionist.com

# Supabase project — anon (publishable) key only. Never the service key.
VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=

# Voice-first launch gate. While false (the default) the SMS / Conversations
# surfaces are shown as "coming soon". Set to true — and the backend SMS_ENABLED
# to true — once A2P 10DLC carrier review clears.
VITE_SMS_ENABLED=false
