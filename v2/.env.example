# SoCal Receptionist V2 — backend service environment.
# Copy to .env for local dev; set as real env vars in production.

PORT=8080

# --- Supabase ---------------------------------------------------------------
# Service role key — backend ONLY, bypasses Row Level Security. Never ship to
# the browser. The admin apps use the anon key instead.
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=

# --- Twilio (shared platform account, ISV model) ----------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Set false ONLY for local testing without a public webhook URL.
TWILIO_VALIDATE_SIGNATURE=true

# --- OpenAI -----------------------------------------------------------------
OPENAI_API_KEY=

# --- Stripe -----------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Recurring monthly plan price (Stripe Price id) — the $500/mo subscription.
STRIPE_PRICE_ID=
# One-time setup fee price (Stripe Price id) — $1,500, billed at checkout and
# includes the first month. Omit to sell a pure monthly subscription.
STRIPE_SETUP_PRICE_ID=

# --- Admin / frontend -------------------------------------------------------
# Public base URL of the web app — used to build Stripe return URLs.
APP_BASE_URL=https://app.socalreceptionist.com

# --- Channels ---------------------------------------------------------------
# Voice-first launch gate. SMS stays dark until A2P 10DLC carrier review clears.
# While false (the default), the /sms webhook only auto-replies "call us
# instead" and the provisioning pipeline skips Twilio messaging setup. The voice
# channel is unaffected. Set to true once A2P registration is approved.
SMS_ENABLED=false

# --- MFA (multi-factor authentication) --------------------------------------
# HMAC secret used to sign per-login MFA tokens. Required once any admin user
# enrols an MFA factor — the MFA endpoints fail loudly if it is missing. Use a
# long random string (e.g. `openssl rand -hex 32`). Never ship to the browser.
MFA_TOKEN_SECRET=

# --- Email (Resend) ---------------------------------------------------------
# App-side transactional mail (onboarding confirmations). Supabase Auth sends
# its own signup / password-reset mail via dashboard SMTP — that is separate.
# If RESEND_API_KEY is unset, email sending no-ops gracefully (local dev).
# The EMAIL_FROM domain must be verified in Resend before mail delivers to
# anyone other than the Resend account owner.
RESEND_API_KEY=
EMAIL_FROM=SoCal Receptionist <noreply@socalreceptionist.com>

# --- Rate limiting / abuse detection ----------------------------------------
RATE_TENANT_PER_MIN=60
RATE_CUSTOMER_PER_MIN=12
ABUSE_PER_MIN=30

# --- Provisioning worker ----------------------------------------------------
WORKER_INTERVAL_MS=5000
# true = run the provisioning worker inside the web process (single-dyno deploy).
RUN_WORKER=false
