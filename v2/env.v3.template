# SoCal Receptionist V3 — development environment
# Copy to .env.v3 and fill in your V3 Supabase credentials.
# Never commit .env.v3 — it contains secrets.

# ── V3 Supabase (separate project from V2 live) ───────────────────────────────
SUPABASE_URL=https://REPLACE_WITH_V3_REF.supabase.co
SUPABASE_ANON_KEY=REPLACE_WITH_V3_ANON_KEY
SUPABASE_SERVICE_KEY=REPLACE_WITH_V3_SERVICE_ROLE_KEY

# Postgres connection string (for running migrations via setup-v3-db.js)
# Password = what you set when creating the Supabase project
V3_DB_URL=postgresql://postgres:REPLACE_WITH_DB_PASSWORD@db.REPLACE_WITH_V3_REF.supabase.co:5432/postgres

# ── Twilio (can reuse V2 or use a test number) ────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_SALES_NUMBER=
TWILIO_VALIDATE_SIGNATURE=false   # set true in prod

# ── OpenAI (Realtime API for voice calls) ─────────────────────────────────────
OPENAI_API_KEY=

# ── Groq (fast LLM for SMS / time tickets / non-voice AI) ────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── Outbound calling ──────────────────────────────────────────────────────────
OUTBOUND_API_KEY=dev-secret-change-me

# ── Practice management integrations ─────────────────────────────────────────
CLIO_CLIENT_ID=
CLIO_CLIENT_SECRET=
MYCASE_CLIENT_ID=
MYCASE_CLIENT_SECRET=

# ── Business config ───────────────────────────────────────────────────────────
BUSINESS_NAME=SoCal Receptionist Dev
BUSINESS_HOURS=Mon-Fri 9am-5pm PST
BUSINESS_SERVICES=AI receptionist, call answering, appointment booking
CALENDLY_LINK=https://calendly.com/your-link
OWNER_EMAIL=your@email.com

# ── Email (Resend or SMTP) ────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── Google Calendar OAuth ─────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ── Stripe (test mode keys for billing) ───────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_

# ── SPA origin for OAuth redirects ───────────────────────────────────────────
APP_BASE_URL=http://localhost:5173
